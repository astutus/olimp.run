---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import HeroPost from '../../components/HeroPost.astro';

const posts = await getCollection('pl');
const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latestPost = sorted[0];
---

<BaseLayout title="Olimp.run – Strona główna">
  <section style="max-width: 600px; margin: 4rem auto; text-align: center;">
    <h1>Witaj na <strong>Olimp.run</strong></h1>
    <p>
      Osobisty blog o <strong>wytrzymałości</strong>, <strong>treningu</strong>, <strong>kalistenice</strong>, 
      <strong>zdrowiu</strong> oraz dyscyplinie, która napędza rozwój.
    </p>
    <p>
      Czasem o technologii. Czasem o psach.  
      Zawsze o <strong>progresie</strong>.
    </p>
  </section>

  <section style="max-width: 600px; margin: 4rem auto;">
    <HeroPost post={latestPost} langPrefix="/pl" readMoreText="Czytaj cały wpis →" />
  </section>
</BaseLayout>

