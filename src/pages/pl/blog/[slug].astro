---
import { getEntryBySlug, getCollection } from 'astro:content';
import BaseLayout from '../../layouts/Base.astro';

const { slug } = Astro.params;
const post = await getEntryBySlug('pl', slug) as any; // 👈 typujemy jako any

if (!post) {
  throw new Error(`Post not found for slug: ${slug}`);
}

const { Content } = await post.render();

export async function getStaticPaths() {
  const posts = await getCollection('pl');
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}
---

<BaseLayout>
  <article style="max-width: 700px; margin: 4rem auto;">
    <h1 style="font-size: 2rem; margin-bottom: 0.5rem;">{post.data.title}</h1>
    <p style="color: #d1d5db; font-style: italic;">{post.data.pubDate.toDateString()}</p>
    <div style="margin-top: 1.5rem;">
      <Content />
    </div>
  </article>
</BaseLayout>

