---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import HeroPost from '../components/HeroPost.astro';

const posts = await getCollection('en');
const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latestPost = sorted[0];
---

<BaseLayout title="Olimp.run – Home">
  <section style="max-width: 600px; margin: 4rem auto; text-align: center;">
    <h1>Welcome to <strong>Olimp.run</strong></h1>
    <p>
      A personal blog about <strong>endurance</strong>, <strong>training</strong>, <strong>calisthenics</strong>, 
      <strong>health</strong>, and the disciplined mindset behind growth.
    </p>
    <p>
      Sometimes about tech. Sometimes about dogs.  
      Always about <strong>progress</strong>.
    </p>
  </section>

  <section style="max-width: 600px; margin: 4rem auto;">
    <HeroPost post={latestPost} />
  </section>
</BaseLayout>
