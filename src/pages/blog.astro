---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import PostPreview from '../components/PostPreview.astro';

const posts = await getCollection('en');
---

<BaseLayout title="Blog – Olimp.run">
  <section style="max-width: 800px; margin: 4rem auto; text-align: center;">
    <h1>Blog</h1>
    <p>Browse the latest posts and insights.</p>
  </section>

  <section style="max-width: 800px; margin: 0 auto; padding: 0 1rem;">
    {
      posts.map((post) => (
        <PostPreview post={post} />
      ))
    }
  </section>
</BaseLayout>

