---
const { post, langPrefix = '', readMoreText = 'Read full post →' } = Astro.props;
const { Content } = await post.render();
---

<article class="hero-post" style="padding: 2rem; background-color: #111827; color: #fff; border-radius: 0.5rem;">
  <h2 style="font-size: 2rem; margin-bottom: 0.5rem;">{post.data.title}</h2>
  <p style="font-size: 0.9rem; color: #d1d5db;"><em>{post.data.pubDate.toDateString()}</em></p>
  <div class="excerpt" style="margin: 1rem 0;">
    <Content />
  </div>
  <a href={`${langPrefix}/blog/${post.slug}`} style="color: #60a5fa;">{readMoreText}</a>
</article>

